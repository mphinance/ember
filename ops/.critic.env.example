# ops/.critic.env — model keys for the rotating critic (ops/critic.py).
# Copy this to ops/.critic.env on the box (that filename is gitignored; the key never
# enters git). With a key set, the critic rotates GPT / Gemini / DeepSeek / Grok / Claude
# etc. via OpenRouter. Without it, the critic falls back to local Sonnet via happy.
#
#   cp ops/.critic.env.example ops/.critic.env   # then paste your key below

OPENROUTER_API_KEY=sk-or-...
