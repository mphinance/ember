//@version=6
// WheelForge Put Zone — companion indicator to the WheelForge scanner.
// Draws where a disciplined premium seller would sell a cash-secured put: a shaded
// band one sigma below price for a ~30 day horizon, sized off realized volatility, with
// the suggested strike highlighted and the zone tinted by how rich the premium is (HV
// rank). It does NOT touch an options chain (Pine cannot), so the strike is the
// statistical put-sell level, not a live quote. Pair it with the scanner for the real fill.
// House style: synthwave neon. No em dashes anywhere (Michael's rule).
indicator("WheelForge Put Zone", shorttitle="WF Puts", overlay=true)

// ── inputs ───────────────────────────────────────────────────────────────────
hvLen   = input.int(20,  "HV lookback (bars)",   minval=5)
dteCal  = input.int(30,  "Horizon (calendar days)", minval=1)
rankLen = input.int(252, "HV-rank lookback",     minval=20)
showLbl = input.bool(true, "Show info label")

// ── synthwave palette ─────────────────────────────────────────────────────────
cPink = color.rgb(255, 45, 149)
cCyan = color.rgb(0, 229, 255)
cVio  = color.rgb(176, 38, 255)
cHot  = color.rgb(255, 122, 24)

// ── realized vol -> sigma over the horizon ────────────────────────────────────
logret = math.log(close / close[1])
hv     = ta.stdev(logret, hvLen) * math.sqrt(252)              // annualized realized vol
tdays  = dteCal * 252.0 / 365.0                               // calendar -> trading days
sigH   = hv * math.sqrt(tdays / 252.0)                        // sigma over the horizon

strike1  = close * (1.0 - sigH)            // the ~1 sigma OTM put to sell
strikeHi = close * (1.0 - 0.7 * sigH)      // top of the sell zone
strikeLo = close * (1.0 - 1.3 * sigH)      // bottom of the sell zone

// ── HV rank: is vol elevated (richer premium to sell)? ────────────────────────
hvHi   = ta.highest(hv, rankLen)
hvLo   = ta.lowest(hv, rankLen)
hvRank = hvHi == hvLo ? 50.0 : (hv - hvLo) / (hvHi - hvLo) * 100.0
zoneCol = color.from_gradient(hvRank, 0, 100, color.new(cCyan, 82), color.new(cHot, 55))

// ── draw the put-sell zone + the suggested strike ─────────────────────────────
pHi = plot(strikeHi, "zone top",    color=color.new(cVio, 60))
pLo = plot(strikeLo, "zone bottom", color=color.new(cVio, 60))
fill(pHi, pLo, color=zoneCol, title="put sell zone")
plot(strike1, "~1 sigma put strike", color=cPink, linewidth=2)

// ── one live info label on the last bar ───────────────────────────────────────
var label lbl = na
if showLbl and barstate.islast
    label.delete(lbl)
    rich = hvRank >= 50 ? "premium is rich" : "premium is thin"
    txt  = "WheelForge\nsell ~" + str.tostring(strike1, format.mintick) + " put (" + str.tostring(dteCal) + "d)" + "\nHV " + str.tostring(hv * 100, "#.#") + "%   rank " + str.tostring(hvRank, "#") + "\n" + rich
    lbl := label.new(bar_index, strikeLo, txt, style=label.style_label_up, color=color.new(color.black, 15), textcolor=cCyan, size=size.small)
